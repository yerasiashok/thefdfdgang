<script>
(function(){
  var sid = '{{ section.id }}';
  var w = document.getElementById('fg-' + sid);
  if(!w) return;
  var S = { upcoming:{index:0,total:5}, trending:{index:0,total:5} };
  function vis(){return window.innerWidth<=640?1:window.innerWidth<=990?3:4;}
  function dots(id){
    var s=S[id], max=Math.max(1,s.total-vis()+1);
    var el=w.querySelector('[data-fg-dots="'+id+'"]');
    if(!el)return; el.innerHTML='';
    for(var i=0;i<max;i++){var d=document.createElement('span');d.className='fg-dot-item'+(i===s.index?' on':'');el.appendChild(d);}
  }
  function move(id,dir){
    var s=S[id],max=Math.max(0,s.total-vis());
    s.index=Math.max(0,Math.min(s.index+parseInt(dir),max));
    var t=w.querySelector('[data-fg-track="'+id+'"]');
    if(!t||!t.children[0])return;
    t.style.transform='translateX(-'+(s.index*(t.children[0].offsetWidth+14))+'px)';
    dots(id);
  }
  function tab(p){
    w.querySelectorAll('.fg-tab').forEach(function(b){b.classList.toggle('on',b.dataset.fgPanel===p);});
    w.querySelectorAll('.fg-panel').forEach(function(b){b.style.display=b.dataset.fgPid===p?'':'none';});
  }
  w.querySelectorAll('.fg-tab').forEach(function(b){b.addEventListener('click',function(){tab(this.dataset.fgPanel);});});
  w.querySelectorAll('.fg-nav-btn').forEach(function(b){b.addEventListener('click',function(){move(this.dataset.fgCar,this.dataset.fgDir);});});
  window.addEventListener('resize',function(){dots('upcoming');dots('trending');});
  dots('upcoming'); dots('trending');
  var end=new Date('2026-04-30T00:00:00').getTime();
  function tick(){
    var diff=Math.max(0,end-Date.now());
    var d=document.getElementById('fg-d-'+sid);
    var h=document.getElementById('fg-h-'+sid);
    var m=document.getElementById('fg-m-'+sid);
    var s=document.getElementById('fg-s-'+sid);
    if(d)d.textContent=String(Math.floor(diff/86400000)).padStart(2,'0');
    if(h)h.textContent=String(Math.floor(diff%86400000/3600000)).padStart(2,'0');
    if(m)m.textContent=String(Math.floor(diff%3600000/60000)).padStart(2,'0');
    if(s)s.textContent=String(Math.floor(diff%60000/1000)).padStart(2,'0');
  }
  tick(); setInterval(tick,1000);
})();
</script>

