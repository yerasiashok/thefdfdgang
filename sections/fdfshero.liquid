          <div class="fg-cimg-inner"><svg width="110" height="130" viewBox="0 0 110 130" fill="none"><path d="M18 24L0 50l18 6v56h74V56l18-6L92 24L73 35Q55 44 37 35Z" fill="#0a0a0a" stroke="#555" stroke-width="1.5" stroke-dasharray="5 3"/><text x="55" y="74" font-family="serif" font-size="10" fill="#555" text-anchor="middle">NTR NEEL</text><text x="55" y="92" font-family="serif" font-size="8" fill="#333" text-anchor="middle">JR NTR</text></svg></div>
        </div>
        <div class="fg-cbody"><div class="fg-ctag fg-ctag-gold">Jr NTR - Telugu</div><div class="fg-cname">NTR - Neel Tee</div><div class="fg-csub">Mass action - Post RRR</div>
          <div class="fg-cfoot"><div class="fg-cprice fg-cprice-tba">TBA</div><a href="/collections/ntr-neel" class="fg-cbtn fg-cbtn-notify">Notify Me</a></div>
        </div>
      </div>

