{% comment %}
  FDFS GANG — Dual Carousel Section
  File: sections/fdfs-gang-carousel.liquid
  
  HOW TO INSTALL:
  1. Go to Shopify Admin → Online Store → Themes → Edit Code
  2. Under "Sections" folder → click "Add a new section"
  3. Name it: fdfs-gang-carousel
  4. Delete the default code and paste this entire file
  5. Click Save
  6. Go to Customize → Homepage → Add Section → FDFS Gang Carousel
  7. Done ✅
{% endcomment %}

<div class="fdfs-carousel-wrapper" id="fdfs-carousel-{{ section.id }}">

  {%- comment -%} ========== STYLES ========== {%- endcomment -%}
  <style>
    #fdfs-carousel-{{ section.id }} {
      background: {{ section.settings.bg_color }};
      padding: 40px 32px 52px;
      font-family: 'Barlow', sans-serif;
    }

    #fdfs-carousel-{{ section.id }} * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* ---- TABS ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-tabs {
      display: flex;
      border-bottom: 1px solid #222;
      margin-bottom: 28px;
      gap: 0;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-tab {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 10px 22px;
      cursor: pointer;
      color: #666;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      transition: color 0.2s, border-color 0.2s;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-tab.is-active {
      color: {{ section.settings.text_color }};
      border-bottom: 2px solid {{ section.settings.accent_color }};
    }

    /* ---- SECTION HEADER ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-eyebrow {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: {{ section.settings.accent_color }};
      margin-bottom: 4px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-section-title {
      font-family: 'Bebas Neue', 'Barlow Condensed', sans-serif;
      font-size: 32px;
      letter-spacing: 3px;
      line-height: 1;
      color: {{ section.settings.text_color }};
    }

    /* ---- NAV ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-nav-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-dots {
      display: flex;
      gap: 5px;
      align-items: center;
      margin-right: 4px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #222;
      transition: all 0.2s;
      display: inline-block;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-dot.is-active {
      background: {{ section.settings.accent_color }};
      width: 16px;
      border-radius: 3px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-nav-btn {
      width: 34px;
      height: 34px;
      border: 1px solid #222;
      background: transparent;
      color: {{ section.settings.text_color }};
      cursor: pointer;
      border-radius: 2px;
      font-size: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, border-color 0.15s;
      line-height: 1;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-nav-btn:hover {
      background: {{ section.settings.accent_color }};
      border-color: {{ section.settings.accent_color }};
    }

    /* ---- TRACK ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-track-wrap {
      overflow: hidden;
      width: 100%;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-track {
      display: flex;
      gap: 14px;
      transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    /* ---- CARD ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-card {
      flex: 0 0 calc(25% - 11px);
      background: #111;
      border: 1px solid #222;
      border-radius: 3px;
      overflow: hidden;
      position: relative;
      min-width: 0;
      transition: border-color 0.2s;
    }

    @media screen and (max-width: 990px) {
      #fdfs-carousel-{{ section.id }} .fdfs-card {
        flex: 0 0 calc(33.333% - 10px);
      }
    }

    @media screen and (max-width: 640px) {
      #fdfs-carousel-{{ section.id }} .fdfs-card {
        flex: 0 0 calc(80% - 8px);
      }
      #fdfs-carousel-{{ section.id }} {
        padding: 28px 16px 40px;
      }
    }

    #fdfs-carousel-{{ section.id }} .fdfs-card:hover .fdfs-cimg-inner {
      transform: scale(1.04);
    }

    #fdfs-carousel-{{ section.id }} .fdfs-card--hero {
      border-color: {{ section.settings.accent_color }};
    }

    #fdfs-carousel-{{ section.id }} .fdfs-highlight-bar {
      height: 3px;
      background: {{ section.settings.accent_color }};
      width: 100%;
    }

    /* ---- CARD IMAGE ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-cimg {
      height: 200px;
      overflow: hidden;
      background: #0d0d0d;
      position: relative;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cimg-inner {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cimg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ---- BADGES ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-badge {
      position: absolute;
      top: 9px;
      left: 9px;
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 2px;
      z-index: 2;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-badge--hero {
      background: {{ section.settings.accent_color }};
      color: #fff;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-badge--live {
      background: {{ section.settings.accent_color }};
      color: #fff;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-badge--pre {
      background: rgba(227,30,36,0.15);
      color: {{ section.settings.accent_color }};
      border: 1px solid rgba(227,30,36,0.3);
    }

    #fdfs-carousel-{{ section.id }} .fdfs-badge--soon {
      background: rgba(201,168,76,0.14);
      color: #C9A84C;
      border: 1px solid rgba(201,168,76,0.3);
    }

    #fdfs-carousel-{{ section.id }} .fdfs-release-tag {
      position: absolute;
      bottom: 9px;
      right: 9px;
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 2px;
      background: rgba(0,0,0,0.8);
      color: {{ section.settings.text_color }};
      z-index: 2;
    }

    /* ---- CARD BODY ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-cbody {
      padding: 13px 14px 16px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-ctag {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: {{ section.settings.accent_color }};
      margin-bottom: 3px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-ctag--gold {
      color: #C9A84C;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cname {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: {{ section.settings.text_color }};
      margin-bottom: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-csub {
      font-size: 11px;
      color: #666;
      margin-bottom: 11px;
      letter-spacing: 0.3px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cfoot {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cprice {
      font-family: 'Bebas Neue', 'Barlow Condensed', sans-serif;
      font-size: 22px;
      letter-spacing: 2px;
      color: {{ section.settings.text_color }};
    }

    #fdfs-carousel-{{ section.id }} .fdfs-cprice--tba {
      color: #3a3a3a;
    }

    /* ---- BUTTONS ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-btn {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 5px 10px;
      border-radius: 2px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-btn--buy {
      background: {{ section.settings.accent_color }};
      color: #fff;
      border: none;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-btn--pre {
      background: transparent;
      color: {{ section.settings.accent_color }};
      border: 1px solid rgba(227,30,36,0.35);
    }

    #fdfs-carousel-{{ section.id }} .fdfs-btn--notify {
      background: transparent;
      color: #C9A84C;
      border: 1px solid rgba(201,168,76,0.3);
    }

    /* ---- SOLD BAR ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-sold-wrap {
      height: 2px;
      background: #1c1c1c;
      border-radius: 1px;
      margin-top: 9px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-sold-bar {
      height: 2px;
      background: {{ section.settings.accent_color }};
      border-radius: 1px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-sold-label {
      font-family: 'Barlow Condensed', 'Barlow', sans-serif;
      font-size: 10px;
      color: #666;
      margin-top: 5px;
      letter-spacing: 0.5px;
    }

    #fdfs-carousel-{{ section.id }} .fdfs-sold-label span {
      color: {{ section.settings.accent_color }};
    }

    /* ---- PLACEHOLDER SVG ---- */
    #fdfs-carousel-{{ section.id }} .fdfs-placeholder {
      width: 110px;
      height: 130px;
    }
  </style>

  {%- comment -%} ========== FONT LOAD ========== {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">

