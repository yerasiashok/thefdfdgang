{%- comment -%} ========== JAVASCRIPT ========== {%- endcomment -%}
<script>
(function() {
  var sectionId = {{ section.id | json }};
  var wrapper   = document.getElementById('fdfs-carousel-' + sectionId);
  if (!wrapper) return;

  var carousels = {
    upcoming: { index: 0, total: 5, visible: 4 },
    trending:  { index: 0, total: 5, visible: 4 }
  };

  function getVisible() {
    var w = window.innerWidth;
    if (w <= 640)  return 1;
    if (w <= 990)  return 3;
    return 4;
  }

  function buildDots(id) {
    var s   = carousels[id];
    s.visible = getVisible();
    var max = Math.max(1, s.total - s.visible + 1);
    var wrap = wrapper.querySelector('[data-dots="' + id + '"]');
    if (!wrap) return;
    wrap.innerHTML = '';
    for (var i = 0; i < max; i++) {
      var d = document.createElement('span');
      d.className = 'fdfs-dot' + (i === s.index ? ' is-active' : '');
      wrap.appendChild(d);
    }
  }

  function slide(id, dir) {
    var s   = carousels[id];
    s.visible = getVisible();
    var max = Math.max(0, s.total - s.visible);
    s.index = Math.max(0, Math.min(s.index + parseInt(dir), max));
    var track = wrapper.querySelector('[data-track="' + id + '"]');
    if (!track) return;
    var card  = track.children[0];
    var gap   = 14;
    var cardW = card.offsetWidth + gap;
    track.style.transform = 'translateX(-' + (s.index * cardW) + 'px)';
    buildDots(id);
  }

  function switchTab(panel) {
    wrapper.querySelectorAll('.fdfs-tab').forEach(function(t) {
      t.classList.remove('is-active');
    });
    wrapper.querySelector('[data-panel="' + panel + '"]').classList.add('is-active');
    wrapper.querySelectorAll('.fdfs-panel').forEach(function(p) {
      p.style.display = p.dataset.panelId === panel ? '' : 'none';
    });
  }

  wrapper.querySelectorAll('.fdfs-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      switchTab(this.dataset.panel);
    });
  });

  wrapper.querySelectorAll('.fdfs-nav-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      slide(this.dataset.carousel, this.dataset.dir);
    });
  });

  window.addEventListener('resize', function() {
    buildDots('upcoming');
    buildDots('trending');
  });

  buildDots('upcoming');
  buildDots('trending');
})();
</script>

