      <div class="fdfs-feature-title">Gang Early Access</div>
      <div class="fdfs-feature-desc">Sign up and get 48-hour early access before every drop goes public. Gang always gets in first.</div>
    </div>
    <div class="fdfs-feature">
      <div class="fdfs-feature-num">04</div>
      <div class="fdfs-feature-title">Fan Made. Fan Approved.</div>
      <div class="fdfs-feature-desc">Designed by fans who show up First Day First Show. Every design captures the energy of release day.</div>
    </div>
  </div>

</div>

<script>
(function() {
  var sid     = {{ section.id | json }};
  var wrapper = document.getElementById('fdfs-main-' + sid);
  if (!wrapper) return;

  var state = {
    upcoming: { index: 0, total: 5 },
    trending:  { index: 0, total: 5 }
  };

  function getVisible() {
    var w = window.innerWidth;
    if (w <= 640)  return 1;
    if (w <= 990)  return 3;
    return 4;
  }

  function buildDots(id) {
    var s   = state[id];
    var max = Math.max(1, s.total - getVisible() + 1);
    var wrap = wrapper.querySelector('[data-fdfs-dots="' + id + '"]');
    if (!wrap) return;
    wrap.innerHTML = '';
    for (var i = 0; i < max; i++) {
      var d = document.createElement('span');
      d.className = 'fdfs-dot' + (i === s.index ? ' is-active' : '');
      wrap.appendChild(d);
    }
  }

  function doSlide(id, dir) {
    var s   = state[id];
    var max = Math.max(0, s.total - getVisible());
    s.index = Math.max(0, Math.min(s.index + parseInt(dir, 10), max));
    var track = wrapper.querySelector('[data-fdfs-track="' + id + '"]');
    if (!track || !track.children[0]) return;
    var gap   = 14;
    var cardW = track.children[0].offsetWidth + gap;
    track.style.transform = 'translateX(-' + (s.index * cardW) + 'px)';
    buildDots(id);
  }

  function switchTab(panel) {
    wrapper.querySelectorAll('.fdfs-tab').forEach(function(t) {
      t.classList.toggle('is-active', t.dataset.fdfsPanel === panel);
    });
    wrapper.querySelectorAll('.fdfs-panel').forEach(function(p) {
      p.style.display = p.dataset.fdfsPanelId === panel ? '' : 'none';
    });
  }

  wrapper.querySelectorAll('.fdfs-tab').forEach(function(btn) {
    btn.addEventListener('click', function() { switchTab(this.dataset.fdfsPanel); });
  });

  wrapper.querySelectorAll('.fdfs-nav-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      doSlide(this.dataset.fdfsCarousel, this.dataset.fdfsDir);
    });
  });

  window.addEventListener('resize', function() {
    buildDots('upcoming');
    buildDots('trending');
  });

  buildDots('upcoming');
  buildDots('trending');

  
  {% if section.settings.show_countdown %}
  var countdownTarget = new Date('{{ section.settings.countdown_date | default: '2026-04-30T00:00:00' }}').getTime();

  function updateCountdown() {
    var now  = Date.now();
    var diff = Math.max(0, countdownTarget - now);

    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000)  / 60000);
    var s = Math.floor((diff % 60000)    / 1000);

    var dEl = document.getElementById('fdfs-days-' + sid);
    var hEl = document.getElementById('fdfs-hrs-'  + sid);
    var mEl = document.getElementById('fdfs-min-'  + sid);
    var sEl = document.getElementById('fdfs-sec-'  + sid);

    if (dEl) dEl.textContent = String(d).padStart(2, '0');
    if (hEl) hEl.textContent = String(h).padStart(2, '0');
    if (mEl) mEl.textContent = String(m).padStart(2, '0');
    if (sEl) sEl.textContent = String(s).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
  {% endif %}

})();
</script>

