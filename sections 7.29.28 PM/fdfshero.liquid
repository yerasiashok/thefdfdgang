<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --fdfs-red:        {{ section.settings.accent_color | default: '#E31E24' }};
    --fdfs-red-dim:    rgba(227,30,36,0.14);
    --fdfs-red-border: rgba(227,30,36,0.28);
    --fdfs-gold:       #C9A84C;
    --fdfs-gold-dim:   rgba(201,168,76,0.13);
    --fdfs-gold-bdr:   rgba(201,168,76,0.28);
    --fdfs-bg:         {{ section.settings.bg_color | default: '#0A0A0A' }};
    --fdfs-bg2:        #111111;
    --fdfs-bg3:        #181818;
    --fdfs-white:      {{ section.settings.text_color | default: '#F5F0E8' }};
    --fdfs-gray:       #666666;
    --fdfs-border:     #222222;
  }

  .fdfs-page {
    background: var(--fdfs-bg);
    color:      var(--fdfs-white);
    font-family: 'Barlow', sans-serif;
  }

  .fdfs-page * { box-sizing: border-box; margin: 0; padding: 0; }

  /* 
     ANNOUNCEMENT TICKER
   */
  .fdfs-ticker {
    background: var(--fdfs-red);
    overflow: hidden;
    height: 34px;
    display: flex;
    align-items: center;
  }

  .fdfs-ticker-inner {
    display: flex;
    gap: 56px;
    animation: fdfsTicker 22s linear infinite;
    white-space: nowrap;
  }

  .fdfs-ticker-item {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .fdfs-ticker-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    display: inline-block;
    flex-shrink: 0;
  }

  @keyframes fdfsTicker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* 
     HERO
   */
  .fdfs-hero {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--fdfs-bg);
  }

  .fdfs-hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 88px,
        rgba(255,255,255,0.018) 88px,
        rgba(255,255,255,0.018) 89px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 88px,
        rgba(255,255,255,0.010) 88px,
        rgba(255,255,255,0.010) 89px
      );
    pointer-events: none;
  }

  .fdfs-hero-accent {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--fdfs-red);
  }

  .fdfs-hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 60px 52px 60px 60px;
    gap: 40px;
  }

  .fdfs-hero-left { flex: 1; max-width: 560px; }

  .fdfs-hero-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--fdfs-red);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .fdfs-hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 26px;
    height: 1px;
    background: var(--fdfs-red);
    flex-shrink: 0;
  }

  .fdfs-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 9vw, 108px);
    line-height: 0.88;
    letter-spacing: 4px;
    color: var(--fdfs-white);
    margin-bottom: 6px;
  }

  .fdfs-hero-title-red {
    color: var(--fdfs-red);
    display: block;
  }

  .fdfs-hero-tagline {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fdfs-gray);
    border-left: 2px solid var(--fdfs-red);
    padding-left: 14px;
    margin-bottom: 36px;
    margin-top: 14px;
  }

  .fdfs-hero-countdown {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 32px;
    background: var(--fdfs-bg2);
    border: 1px solid var(--fdfs-border);
    border-left: 3px solid var(--fdfs-red);
    padding: 14px 20px;
    width: fit-content;
  }

  .fdfs-hero-countdown-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fdfs-red);
    margin-right: 20px;
    white-space: nowrap;
  }

  .fdfs-timer-units {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .fdfs-timer-unit { text-align: center; }

  .fdfs-timer-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--fdfs-white);
    line-height: 1;
    display: block;
    min-width: 38px;
  }

  .fdfs-timer-lbl {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fdfs-gray);
    display: block;
  }

  .fdfs-timer-sep {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    color: var(--fdfs-red);
    margin: 0 2px;
    padding-bottom: 14px;
  }

  .fdfs-hero-cta {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .fdfs-btn-primary {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    background: var(--fdfs-red);
    color: #fff;
    border: none;
    padding: 14px 28px;
    cursor: pointer;
    border-radius: 2px;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.15s;
  }

  .fdfs-btn-primary:hover { opacity: 0.88; }

  .fdfs-btn-ghost {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    background: transparent;
    color: var(--fdfs-white);
    border: 1px solid var(--fdfs-border);
    padding: 14px 28px;
    cursor: pointer;
    border-radius: 2px;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.15s, color 0.15s;
  }

  .fdfs-btn-ghost:hover {
    border-color: var(--fdfs-white);
  }

  /* Hero right  product showcase */
  .fdfs-hero-right {
    flex-shrink: 0;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .fdfs-hero-product {
    background: var(--fdfs-bg2);
    border: 1px solid var(--fdfs-border);
    border-radius: 3px;
    overflow: hidden;
    width: 186px;
    position: relative;
    transition: border-color 0.2s;
  }

  .fdfs-hero-product:first-child {
    border-color: var(--fdfs-red);
    margin-top: -16px;
  }

  .fdfs-hero-product:hover { border-color: var(--fdfs-red); }

  .fdfs-hero-product-img {
    height: 190px;
    background: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .fdfs-hero-product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fdfs-hero-product-badge {
    position: absolute;
    top: 8px; left: 8px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 2px;
    background: var(--fdfs-red);
    color: #fff;
    z-index: 2;
  }

  .fdfs-hero-product-body { padding: 12px 13px 14px; }

  .fdfs-hero-product-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fdfs-red);
    margin-bottom: 3px;
  }

  .fdfs-hero-product-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--fdfs-white);
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .fdfs-hero-product-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--fdfs-white);
  }

  /* 
     DIVIDER LINE
   */
  .fdfs-divider {
    height: 1px;
    background: var(--fdfs-border);
  }

  /* 
     CAROUSEL SECTION
   */
  .fdfs-carousels {
    background: var(--fdfs-bg);
    padding: 40px 32px 52px;
  }

  /* Tabs */
  .fdfs-tabs {
    display: flex;
    border-bottom: 1px solid var(--fdfs-border);
    margin-bottom: 28px;
  }

  .fdfs-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 10px 22px;
    cursor: pointer;
    color: var(--fdfs-gray);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .fdfs-tab.is-active {
    color: var(--fdfs-white);
    border-bottom: 2px solid var(--fdfs-red);
  }

  /* Section header */
  .fdfs-sec-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .fdfs-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fdfs-red);
    margin-bottom: 4px;
  }

  .fdfs-sec-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 3px;
    line-height: 1;
    color: var(--fdfs-white);
  }

  /* Nav */
  .fdfs-nav-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .fdfs-dots {
    display: flex;
    gap: 5px;
    align-items: center;
    margin-right: 4px;
  }

  .fdfs-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--fdfs-border);
    display: inline-block;
    transition: all 0.2s;
  }

  .fdfs-dot.is-active {
    background: var(--fdfs-red);
    width: 16px;
    border-radius: 3px;
  }

  .fdfs-nav-btn {
    width: 34px;
    height: 34px;
    border: 1px solid var(--fdfs-border);
    background: transparent;
    color: var(--fdfs-white);
    cursor: pointer;
    border-radius: 2px;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    line-height: 1;
  }

  .fdfs-nav-btn:hover {
    background: var(--fdfs-red);
    border-color: var(--fdfs-red);
  }

  /* Track */
  .fdfs-track-wrap { overflow: hidden; width: 100%; }

  .fdfs-track {
    display: flex;
    gap: 14px;
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* Card */
  .fdfs-card {
    flex: 0 0 calc(25% - 11px);
    background: var(--fdfs-bg2);
    border: 1px solid var(--fdfs-border);
    border-radius: 3px;
    overflow: hidden;
    position: relative;
    min-width: 0;
  }

  .fdfs-card--hero { border-color: var(--fdfs-red); }

  .fdfs-card:hover .fdfs-cimg-inner { transform: scale(1.04); }

  .fdfs-highlight-bar {
    height: 3px;
    background: var(--fdfs-red);
    width: 100%;
  }

  .fdfs-cimg {
    height: 196px;
    overflow: hidden;
    background: #0d0d0d;
    position: relative;
  }

  .fdfs-cimg-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .fdfs-cimg-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fdfs-badge {
    position: absolute;
    top: 9px; left: 9px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    z-index: 2;
  }

  .fdfs-badge--hero { background: var(--fdfs-red); color: #fff; }
  .fdfs-badge--live { background: var(--fdfs-red); color: #fff; }
  .fdfs-badge--pre  { background: var(--fdfs-red-dim); color: var(--fdfs-red); border: 1px solid var(--fdfs-red-border); }
  .fdfs-badge--soon { background: var(--fdfs-gold-dim); color: var(--fdfs-gold); border: 1px solid var(--fdfs-gold-bdr); }

  .fdfs-rel-tag {
    position: absolute;
    bottom: 9px; right: 9px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    background: rgba(0,0,0,0.8);
    color: var(--fdfs-white);
    z-index: 2;
  }

  .fdfs-cbody { padding: 13px 14px 16px; }

  .fdfs-ctag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fdfs-red);
    margin-bottom: 3px;
  }

  .fdfs-ctag--gold { color: var(--fdfs-gold); }

  .fdfs-cname {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--fdfs-white);
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fdfs-csub {
    font-size: 11px;
    color: var(--fdfs-gray);
    margin-bottom: 11px;
  }

  .fdfs-cfoot {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .fdfs-cprice {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--fdfs-white);
  }

  .fdfs-cprice--tba { color: #3a3a3a; }

  .fdfs-cbtn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    border: none;
  }

  .fdfs-cbtn--buy    { background: var(--fdfs-red); color: #fff; }
  .fdfs-cbtn--pre    { background: transparent; color: var(--fdfs-red); border: 1px solid var(--fdfs-red-border); }
  .fdfs-cbtn--notify { background: transparent; color: var(--fdfs-gold); border: 1px solid var(--fdfs-gold-bdr); }

  .fdfs-sold-wrap {
    height: 2px;
    background: #1c1c1c;
    border-radius: 1px;
    margin-top: 9px;
  }

  .fdfs-sold-bar {
    height: 2px;
    background: var(--fdfs-red);
    border-radius: 1px;
  }

  .fdfs-sold-lbl {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    color: var(--fdfs-gray);
    margin-top: 5px;
  }

  .fdfs-sold-lbl span { color: var(--fdfs-red); }

  /* 
     FEATURE STRIP
   */
  .fdfs-features {
    background: var(--fdfs-bg2);
    border-top: 1px solid var(--fdfs-border);
    display: flex;
    gap: 0;
  }

  .fdfs-feature {
    flex: 1;
    padding: 28px 24px;
    border-right: 1px solid var(--fdfs-border);
    position: relative;
  }

  .fdfs-feature:last-child { border-right: none; }

  .fdfs-feature::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: transparent;
    transition: background 0.2s;
  }

  .fdfs-feature:hover::before { background: var(--fdfs-red); }

  .fdfs-feature-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: #1c1c1c;
    line-height: 1;
    position: absolute;
    right: 14px; top: 10px;
  }

  .fdfs-feature-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--fdfs-white);
    margin-bottom: 5px;
    margin-top: 4px;
  }

  .fdfs-feature-desc {
    font-size: 12px;
    color: var(--fdfs-gray);
    line-height: 1.6;
  }

  /* 
     RESPONSIVE
   */
  @media screen and (max-width: 990px) {
    .fdfs-hero-right { display: none; }
    .fdfs-hero-inner { padding: 48px 32px; }
    .fdfs-card { flex: 0 0 calc(33.333% - 10px); }
    .fdfs-features { flex-wrap: wrap; }
    .fdfs-feature { flex: 0 0 50%; border-bottom: 1px solid var(--fdfs-border); }
  }

  @media screen and (max-width: 640px) {
    .fdfs-hero-inner { padding: 36px 20px; }
    .fdfs-hero-title { font-size: 72px; }
    .fdfs-hero-countdown { flex-direction: column; gap: 8px; align-items: flex-start; }
    .fdfs-hero-countdown-label { margin-right: 0; }
    .fdfs-card { flex: 0 0 78%; }
    .fdfs-carousels { padding: 28px 16px 40px; }
    .fdfs-feature { flex: 0 0 100%; }
  }
</style>

<div class="fdfs-page" id="fdfs-main-{{ section.id }}">

  
  <div class="fdfs-ticker" aria-hidden="true">
    <div class="fdfs-ticker-inner">
      <span class="fdfs-ticker-item">{{ section.settings.ticker_1 | default: 'Free shipping USA orders above $60' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_2 | default: 'India orders ship in 35 days via Qikink' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_3 | default: 'Limited drops every release week' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_4 | default: 'Gang members get 48-hr early access' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_1 | default: 'Free shipping USA orders above $60' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_2 | default: 'India orders ship in 35 days via Qikink' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_3 | default: 'Limited drops every release week' }}<span class="fdfs-ticker-dot"></span></span>
      <span class="fdfs-ticker-item">{{ section.settings.ticker_4 | default: 'Gang members get 48-hr early access' }}<span class="fdfs-ticker-dot"></span></span>
    </div>
  </div>

  
  <section class="fdfs-hero">
    <div class="fdfs-hero-bg"></div>
    <div class="fdfs-hero-accent"></div>

    <div class="fdfs-hero-inner">

      
      <div class="fdfs-hero-left">

        <div class="fdfs-hero-eyebrow">
          {{ section.settings.hero_eyebrow | default: 'Hero Drop  Apr 30 2026' }}
        </div>

        <div class="fdfs-hero-title">
          {{ section.settings.hero_title_line1 | default: 'FDFS' }}
          <span class="fdfs-hero-title-red">{{ section.settings.hero_title_line2 | default: 'GANG' }}</span>
        </div>

        <div class="fdfs-hero-tagline">
          {{ section.settings.hero_tagline | default: 'Born in the Theatre. Built for the Streets.' }}
        </div>

        
        {% if section.settings.show_countdown %}
        <div class="fdfs-hero-countdown">
          <div class="fdfs-hero-countdown-label">
            {{ section.settings.countdown_label | default: 'Peddi releases in' }}
          </div>
          <div class="fdfs-timer-units">
            <div class="fdfs-timer-unit">
              <span class="fdfs-timer-num" id="fdfs-days-{{ section.id }}">39</span>
              <span class="fdfs-timer-lbl">Days</span>
            </div>
            <span class="fdfs-timer-sep">:</span>
            <div class="fdfs-timer-unit">
              <span class="fdfs-timer-num" id="fdfs-hrs-{{ section.id }}">14</span>
              <span class="fdfs-timer-lbl">Hrs</span>
            </div>
            <span class="fdfs-timer-sep">:</span>
            <div class="fdfs-timer-unit">
              <span class="fdfs-timer-num" id="fdfs-min-{{ section.id }}">22</span>
              <span class="fdfs-timer-lbl">Min</span>
            </div>
            <span class="fdfs-timer-sep">:</span>
            <div class="fdfs-timer-unit">
              <span class="fdfs-timer-num" id="fdfs-sec-{{ section.id }}">00</span>
              <span class="fdfs-timer-lbl">Sec</span>
            </div>
          </div>
