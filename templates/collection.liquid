<div style="padding:60px 40px;background:#0A0A0A;color:#F5F0E8;font-family:'Barlow',sans-serif;">
  <h1 style="font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:3px;color:#F5F0E8;">{{ collection.title }}</h1>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;margin-top:32px;">
    {% for product in collection.products %}
      <a href="{{ product.url }}" style="text-decoration:none;background:#111;border:1px solid #222;border-radius:3px;overflow:hidden;display:block;">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" style="width:100%;aspect-ratio:1;object-fit:cover;">
        {% endif %}
        <div style="padding:14px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#F5F0E8;">{{ product.title }}</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:#E31E24;margin-top:6px;">{{ product.price | money }}</div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
