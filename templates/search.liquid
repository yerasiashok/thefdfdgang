<div style="padding:60px 40px;background:#0A0A0A;color:#F5F0E8;font-family:'Barlow',sans-serif;min-height:60vh;">
  <h1 style="font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:3px;">Search</h1>
  <form action="/search" method="get" style="margin-top:24px;display:flex;gap:12px;">
    <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Search products..."
      style="flex:1;background:#111;border:1px solid #333;color:#F5F0E8;padding:12px 16px;font-family:'Barlow',sans-serif;font-size:14px;border-radius:2px;">
    <button type="submit" style="font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;background:#E31E24;color:#fff;border:none;padding:12px 24px;cursor:pointer;border-radius:2px;">Search</button>
  </form>
</div>
