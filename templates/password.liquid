<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <style>
    body{margin:0;background:#0A0A0A;color:#F5F0E8;font-family:'Barlow',sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;}
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@700&display=swap');
    h1{font-family:'Bebas Neue',sans-serif;font-size:72px;letter-spacing:4px;color:#E31E24;margin:0;}
    p{color:#666;letter-spacing:2px;text-transform:uppercase;font-size:12px;}
    input{background:#111;border:1px solid #333;color:#F5F0E8;padding:12px 16px;font-size:14px;border-radius:2px;margin-right:8px;}
    button{background:#E31E24;color:#fff;border:none;padding:12px 24px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border-radius:2px;}
  </style>
</head>
<body>
  <div style="text-align:center;padding:40px;">
    <h1>FDFS GANG</h1>
    <p style="margin:16px 0 32px;">Born in the Theatre. Built for the Streets.</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Enter password">
      <button type="submit">Enter</button>
    {% endform %}
  </div>
</body>
</html>
