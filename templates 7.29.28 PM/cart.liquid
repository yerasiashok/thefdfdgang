<div style="padding:60px 40px;background:#0A0A0A;color:#F5F0E8;font-family:'Barlow',sans-serif;min-height:60vh;">
  <h1 style="font-family:'Bebas Neue',sans-serif;font-size:48px;letter-spacing:3px;">Your Cart</h1>
  {% if cart.item_count == 0 %}
    <p style="color:#666;margin-top:24px;">Your cart is empty. <a href="/collections/all" style="color:#E31E24;">Keep shopping</a></p>
  {% else %}
    <form action="/cart" method="post">
      {% for item in cart.items %}
        <div style="display:flex;gap:20px;padding:20px 0;border-bottom:1px solid #222;align-items:center;">
          <img src="{{ item.image | image_url: width: 100 }}" style="width:80px;height:80px;object-fit:cover;border-radius:2px;">
          <div style="flex:1;">
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;letter-spacing:1px;text-transform:uppercase;">{{ item.title }}</div>
            <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:#E31E24;margin-top:4px;">{{ item.price | money }}</div>
          </div>
        </div>
      {% endfor %}
      <div style="margin-top:32px;text-align:right;">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:28px;margin-bottom:16px;">Total: {{ cart.total_price | money }}</div>
        <button type="submit" name="checkout" style="font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;background:#E31E24;color:#fff;border:none;padding:14px 32px;cursor:pointer;border-radius:2px;">Checkout</button>
      </div>
    </form>
  {% endif %}
</div>
